{
    "dockerComposeFile": ["../docker-compose.yml", "docker-compose.yml"],
    "service": "tabletop",
    "workspaceFolder": "/workspace",
    "shutdownAction": "stopCompose",
    "postCreateCommand": "sudo chown -R node:node /workspace/node_modules; pnpm install; turbo init-project",
    "features": {
        "ghcr.io/stuartleeks/dev-container-features/shell-history:0": {}
    },
    "forwardPorts": [5174],
    "portsAttributes": {
        "5174": {
            "label": "Santiago UI",
            "onAutoForward": "notify"
        }
    },
    "customizations": {
        "vscode": {
            "extensions": ["1YiB.svelte-bundle", "esbenp.prettier-vscode", "anthropic.claude-code"]
        }
    }
}
